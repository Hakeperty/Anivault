{
  "appId": "com.anivault.app",
  "appName": "AniVault",
  "webDir": "src",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "Filesystem": {
      "checkPermissions": true,
      "requestPermissions": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  }
}